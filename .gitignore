# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
.utmp/

src/*/[Ll]ibrary/
src/*/*/[Ll]ibrary/

src/*/[Tt]emp/
src/*/*/[Tt]emp/

src/*/[Oo]bj/
src/*/*/[Oo]bj/

src/*/[Bb]uild/
src/*/*/[Bb]uild/

src/*/[Bb]uilds/
src/*/*/[Bb]uilds/

src/*/[Ll]ogs/
src/*/*/[Ll]ogs/

src/*/[Uu]ser[Ss]ettings/
src/*/*/[Uu]ser[Ss]ettings/

src/*.log
src/*/*.log

# By default unity supports Blender asset imports, *.blend1 blender files do not need to be commited to version control.
src/*/*.blend1
src/*/*/*.blend1

src/*/*.blend1.meta
src/*/*/*.blend1.meta

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
src/*/[Mm]emoryCaptures/
src/*/*/[Mm]emoryCaptures/

# Recordings can get excessive in size
src/*/[Rr]ecordings/
src/*/*/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
src/*/[Aa]ssets/AssetStoreTools*
src/*/*/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
src/*/[Aa]ssets/Plugins/Editor/JetBrains*
src/*/*/[Aa]ssets/Plugins/Editor/JetBrains*
# Jetbrains Rider personal-layer settings
src/*/*.DotSettings.user
src/*/*/*.DotSettings.user

# Visual Studio cache directory
src/*/.vs/
src/*/*/.vs/

# Gradle cache directory
src/*/.gradle/
src/*/*/.gradle/

# Autogenerated VS/MD/Consulo solution and project files
src/*/ExportedObj/
src/*/*/ExportedObj/

src/*/.consulo/
src/*/*/.consulo/

src/*/*.csproj
src/*/*/*.csproj

src/*/*.unityproj
src/*/*/*.unityproj

src/*/*.sln
src/*/*/*.sln

src/*/*.suo
src/*/*/*.suo

src/*/*.tmp
src/*/*/*.tmp

src/*/*.user
src/*/*/*.user

src/*/*.userprefs
src/*/*/*.userprefs

src/*/*.pidb
src/*/*/*.pidb

src/*/*.booproj
src/*/*/*.booproj

src/*/*.svd
src/*/*/*.svd

src/*/*.pdb
src/*/*/*.pdb

src/*/*.mdb
src/*/*/*.mdb

src/*/*.opendb
src/*/*/*.opendb

src/*/*.VC.db
src/*/*/*.VC.db

# Unity3D generated meta files
src/*/*.pidb.meta
src/*/*/*.pidb.meta

src/*/*.pdb.meta
src/*/*/*.pdb.meta

src/*/*.mdb.meta
src/*/*/*.mdb.meta

# Unity3D generated file on crash reports
src/*/sysinfo.txt
src/*/*/sysinfo.txt

# Mono auto generated files
src/*/mono_crash.*
src/*/*/mono_crash.*

# Builds
src/*/*.apk
src/*/*/*.apk

src/*/*.aab
src/*/*/*.aab

src/*/*.unitypackage
src/*/*/*.unitypackage

src/*/*.unitypackage.meta
src/*/*/*.unitypackage.meta

src/*/*.app
src/*/*/*.app

# Crashlytics generated file
src/*/crashlytics-build.properties
src/*/*/crashlytics-build.properties

# TestRunner generated files
src/*/InitTestScene*.unity*
src/*/*/InitTestScene*.unity*

# Addressables default ignores, before user customizations
src/*/ServerData
src/*/*/ServerData

src/*/[Aa]ssets/StreamingAssets/aa*
src/*/*/[Aa]ssets/StreamingAssets/aa*

src/*/[Aa]ssets/AddressableAssetsData/link.xml*
src/*/*/[Aa]ssets/AddressableAssetsData/link.xml*

src/*/[Aa]ssets/Addressables_Temp*
src/*/*/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
src/*/[Aa]ssets/AddressableAssetsData/*/*.bin*
src/*/*/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
src/*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
src/*/*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db

src/*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
src/*/*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta

src/*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
src/*/*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers

src/*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta
src/*/*/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
src/*/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*
src/*/*/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

#Visual Studio 2026 new config files
.vs/
.vs/*
.vs/*/*

